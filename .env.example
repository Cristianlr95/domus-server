# Runtime profile
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=domus_dev
DB_USERNAME=domus_dev
DB_PASSWORD=domus_dev
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT_MS=30000
DB_POOL_VALIDATION_TIMEOUT_MS=5000

# Security
# Generate a strong Base64 secret for production.
JWT_SECRET=REPLACE_WITH_A_STRONG_BASE64_SECRET
JWT_EXPIRATION_SECONDS=28800
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100,http://127.0.0.1:8100
APP_SECURITY_EXPOSE_DOCS=true

# Operations
MANAGEMENT_EXPOSED_ENDPOINTS=health,info
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
